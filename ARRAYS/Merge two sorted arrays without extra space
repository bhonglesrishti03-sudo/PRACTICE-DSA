class Solution {
    public void merge(int[] nums1, int m, int[] nums2, int n) {
    
    //Approach 1 
    int i = m , j = 0;
   while(i<nums1.length && j < nums2.length){
        //we want that the numbers of nums2 should be placed on the placeholders that are basically zeroes
        nums1[i] = nums2[j];
        i++;
        j++;
    }
    Arrays.sort(nums1);
    }
}
