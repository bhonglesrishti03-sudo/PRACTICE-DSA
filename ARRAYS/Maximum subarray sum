class Solution {
    public int maxSubArray(int[] nums) {
       // KADANES ALGORITHM
       // if we ever encounter any negative sum or sum =0 then drop that sum basically adding negative values will always reduce the sum hence adding them is just more memory consumption and just a waste .
       int max=nums[0];
       int sum =0;
       for(int i=0; i< nums.length; i++){
        sum+=nums[i];
        if(sum > max){
            max = sum;
        }
        if(sum < 0){
            sum =0;
        }
       }
 return max;
    }
}

 
