class Solution {
    public int maxProfit(int[] prices) {
     int profit = 0;
     int buyingDay = prices[0];
     //treat each day as a sellingDay
     for(int i=0; i<prices.length ;i++){
        buyingDay = Math.min(buyingDay,prices[i]);
        profit = Math.max(profit,prices[i] - buyingDay);
     }
      return profit;
    }
}
