class Solution {
    public int trap(int[] height) {
        //brute force approach
     int n = height.length;
     int totalWater = 0;
     //at every index you need a leftMaxHeight and rightMaxHeight
     for(int i=0; i<n; i++){
        int leftMax = 0 , rightMax = 0;
       //finding leftMax
       for(int j = 0; j<=i; j++){
        leftMax = Math.max(leftMax,height[j]);
       }

       //finding rightMax
       for(int j = i ;j<n ;j++){
        rightMax = Math.max(rightMax,height[j]);
       }
       totalWater += Math.min(leftMax , rightMax) - height[i];
     }
     return totalWater;
     }
    }
